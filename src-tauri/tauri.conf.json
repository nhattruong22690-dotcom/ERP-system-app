{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ERPApp",
  "version": "0.1.13",
  "identifier": "com.taichinh.erp",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Xinh Group ERP",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "RWTWo9MDn8J9k/N92vHFOx48ZLLKJhA0jvZx9bGlT37yY4PorTSpi+GU",
      "endpoints": [
        "https://github.com/nhattruong22690-dotcom/ERP-system-app/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}